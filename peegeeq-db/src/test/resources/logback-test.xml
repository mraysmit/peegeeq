<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <conversionRule conversionWord="vxTrace" 
                    class="dev.mars.peegeeq.api.logging.VertxTraceIdConverter" />
    <conversionRule conversionWord="vxSpan" 
                    class="dev.mars.peegeeq.api.logging.VertxSpanIdConverter" />

    <!-- Test-specific console appender with simplified pattern -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - [trace=%vxTrace span=%vxSpan] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Root logger for tests - INFO level to reduce noise -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>

    <!-- PeeGeeQ specific loggers -->
    <logger name="dev.mars.peegeeq" level="WARN" />
    
    <!-- Show close-reactive error propagation test procedure -->
    <logger name="dev.mars.peegeeq.db.PeeGeeQManagerCloseReactiveErrorPropagationTest" level="INFO" />
    <!-- Show intentional-blocking test procedure: expected-WARN annotations -->
    <logger name="dev.mars.peegeeq.db.performance.VertxEventLoopBlockingJoinTest" level="INFO" />
    
    <!-- Reduce TestContainers noise -->
    <logger name="org.testcontainers" level="WARN" />
    <logger name="com.github.dockerjava" level="WARN" />
    <logger name="tc" level="WARN" />

    <!-- Suppress noisy duplicate-object warnings from idempotent Flyway migrations. -->
    <logger name="org.flywaydb.core.internal.sqlscript.DefaultSqlScriptExecutor" level="ERROR" />

    <!-- Suppress PostgreSQL NOTICE messages (42P06 schema already exists, 42P07 relation already exists)
         which Vert.x SQL client promotes to WARN. These are expected from IF NOT EXISTS DDL. -->
    <logger name="io.vertx.sqlclient.impl.SocketConnectionBase" level="ERROR" />
    
    <!-- Reduce Hikari connection pool noise -->
    <logger name="com.zaxxer.hikari" level="WARN" />
    
    <!-- Reduce Vert.x noise -->
    <logger name="io.vertx" level="WARN" />
    
    <!-- Keep configuration warnings visible but reduce debug noise -->
    <logger name="dev.mars.peegeeq.db.config.PeeGeeQConfiguration" level="WARN" />
    
    <!-- Show important application events -->
    <!--
    Test debug logging control for PeeGeeQ DB components:
    - Set to DEBUG to see detailed database operation logging during tests
    - Set to INFO to see only important database events during tests
    - Set to WARN to minimize database logging during tests
    -->
    <logger name="dev.mars.peegeeq.db.PeeGeeQManager" level="DEBUG" />
    <logger name="dev.mars.peegeeq.db.provider.PgConnectionProvider" level="INFO" />
    <logger name="dev.mars.peegeeq.db.provider.PgDatabaseService" level="INFO" />
    <logger name="dev.mars.peegeeq.db.provider.PgQueueFactoryProvider" level="DEBUG" />
    <logger name="dev.mars.peegeeq.db.migration.SchemaMigrationManager" level="DEBUG" />
    <logger name="dev.mars.peegeeq.db.connection.PgConnectionManager" level="DEBUG" />
    <logger name="dev.mars.peegeeq.db.health.HealthCheckManager" level="INFO" />
    <logger name="dev.mars.peegeeq.db.metrics.PeeGeeQMetrics" level="WARN" />

    <!-- Full debug output for the HAProxy failover/failback test -->
    <logger name="dev.mars.peegeeq.db.resilience.HaProxyConnectionFailoverTest" level="DEBUG" />
    
    <!-- Reduce migration noise -->
    <logger name="dev.mars.peegeeq.db.migration.SchemaMigrationManager" level="WARN" />
    
    <!-- Show queue operations but reduce debug noise -->
    <logger name="dev.mars.peegeeq.pgqueue" level="WARN" />
    
    <!-- Consumer group / backfill / dead consumer logging -->
    <logger name="dev.mars.peegeeq.db.subscription" level="INFO" />
    <logger name="dev.mars.peegeeq.db.cleanup" level="INFO" />
    <logger name="dev.mars.peegeeq.db.fanout" level="INFO" />

    <!-- Detailed debug logging for consumer group / completion / retry tests -->
    <logger name="dev.mars.peegeeq.db.consumer" level="DEBUG" />
    <logger name="dev.mars.peegeeq.db.deadletter" level="DEBUG" />
    <logger name="dev.mars.peegeeq.db.examples" level="DEBUG" />

    <!-- Suppress intentional test failure stack traces from PgQueueFactoryProvider -->
    <!-- This prevents confusing error logs during intentional failure tests -->
    <logger name="dev.mars.peegeeq.db.provider.PgQueueFactoryProvider" level="OFF" />
</configuration>

